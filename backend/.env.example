# Environment Configuration - SECURE EDITION
# Copy this file to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/puzzlechain

# JWT Secrets (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Frontend URL (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Stripe (CHANGE IN PRODUCTION!)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Internal API Key (CHANGE IN PRODUCTION!)
INTERNAL_API_KEY=your-internal-api-key-change-in-production-min-32-chars

# Admin IDs (comma separated)
ADMIN_IDS=admin1,admin2

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
