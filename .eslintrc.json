{\n  "env": {\n    "node": true,\n    "es2020": true\n  },\n  "extends": [\n    "eslint:recommended"\n  ],\n  "parserOptions": {\n    "ecmaVersion": 11,\n    "sourceType": "module"\n  },\n  "rules": {\n    "semi": ["error", "always"],\n    "quotes": ["error", "single"],\n    "no-console": "warn",\n    "eqeqeq": "error",\n    "curly": "error",\n    "strict": ["error", "global"],\n    "no-unused-vars": ["error", {"argsIgnorePattern": "^_"}]\n  }\n}